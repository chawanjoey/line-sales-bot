# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# OpenRouter API (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model ที่ใช้ (เปลี่ยนได้ตลอด)
# แนะนำ: anthropic/claude-sonnet-4-5
# ถูกกว่า: anthropic/claude-haiku-4-5-20251001
# ทางเลือก: google/gemini-2.5-pro, openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# URL ของ app (ใส่ domain จริงตอน deploy)
APP_URL=https://your-domain.com

# PostgreSQL — Neon หรือ Database อื่นที่มีข้อมูลพนักงาน
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Admin Dashboard Token
ADMIN_TOKEN=your_secure_admin_token_here

# Server
PORT=3002
